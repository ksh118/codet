    <script>
        const whiteLogo = "https://i.ifh.cc/bfXwm6.png";
        const blackLogo = "https://i.ifh.cc/L9Pwjg.png";
        const headerLogo = document.getElementById('headerLogo');

        window.addEventListener('load', () => {
            const loader = document.getElementById('loading-screen');
            const content = document.getElementById('main-content');
            setTimeout(() => {
                document.documentElement.style.overflow = 'auto';
                loader.style.opacity = '0';
                content.style.opacity = '1';
                setTimeout(() => {
                    loader.style.display = 'none';
                    document.documentElement.style.scrollBehavior = 'smooth';
                }, 500);
            }, 1200);
        });

        const targetSection = document.getElementById('targetSection');
        window.addEventListener('scroll', () => {
            if (window.scrollY > targetSection.offsetTop - (window.innerHeight * 0.7)) {
                document.body.classList.add('light-mode');
                headerLogo.src = blackLogo;
            } else {
                document.body.classList.remove('light-mode');
                headerLogo.src = whiteLogo;
            }
        });

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    entry.target.querySelectorAll('.reveal').forEach(el => el.classList.add('active'));
                } else {
                    entry.target.classList.remove('active');
                    entry.target.querySelectorAll('.reveal').forEach(el => el.classList.remove('active'));
                }
            });
        }, { threshold: 0.5 });
        document.querySelectorAll('section').forEach(el => observer.observe(el));
    </script>
