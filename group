    <style>
        /* 로딩 및 레이아웃 설정 */
        #loading-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; display: flex; flex-direction: column;
            justify-content: center; align-items: center; z-index: 10000;
        }
        .loading-logo { width: 150px; height: auto; margin-bottom: 25px; opacity: 0; animation: fadeIn 0.8s forwards; }
        .loader { width: 24px; height: 24px; border: 2px solid rgba(255,255,255,0.1); border-top: 2px solid #fff; border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @keyframes fadeIn { to { opacity: 1; } }

        #main-content { opacity: 0; transition: opacity 0.8s ease; }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        
        /* 자석 스크롤 설정 */
        html { scroll-snap-type: y mandatory; height: 100%; overflow-x: hidden; }
        body { background-color: #000; color: #fff; transition: background-color 0.8s ease; width: 100%; -webkit-font-smoothing: antialiased; }
        body.light-mode { background-color: #fff; color: #000; }

        /* 헤더 및 버튼 */
        header { position: fixed; top: 0; width: 100%; padding: 25px 30px; display: flex; justify-content: space-between; align-items: center; z-index: 1000; }
        .logo-container { display: flex; align-items: center; text-decoration: none; color: inherit; gap: 10px; }
        .logo-img { height: 26px; width: auto; object-fit: contain; transition: opacity 0.3s ease; }
        .logo-text { font-size: 22px; font-weight: 900; letter-spacing: -0.5px; }
        
        .header-btn { 
            background: #fff; color: #000; padding: 10px 20px; border-radius: 50px; 
            text-decoration: none; font-weight: 700; font-size: 14px; transition: all 0.3s ease;
        }
        body.light-mode .header-btn { background: #000; color: #fff; }

        section { 
            position: relative; width: 100%; min-height: 100vh; 
            display: flex; flex-direction: column; align-items: center; justify-content: center; 
            scroll-snap-align: start; scroll-snap-stop: always; padding: 0 24px; overflow: hidden;
        }

        .hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://i.ifh.cc/Xg75FD.jpg') no-repeat center/cover; z-index: -1; }
        .hero-title h1 span { display: inline-block; opacity: 0; transform: translateX(-20px); animation: sequentialIn 0.8s forwards; font-size: clamp(48px, 11vw, 84px); font-weight: 800; letter-spacing: -2px; }
        .hero-title p { opacity: 0; animation: fadeIn 1s forwards 1.2s; font-size: clamp(16px, 4vw, 20px); color: rgba(255,255,255,0.7); margin-top: 20px; text-align: center; }

        @keyframes sequentialIn { to { opacity: 1; transform: translateX(0); } }

        /* 두 번째 섹션 - 흰색 빛 효과 */
        .black-box-section { background-color: #000; text-align: center; }
        .light-glow {
            position: absolute; top: 50%; left: 50%; width: 0; height: 0;
            background: rgba(255, 255, 255, 0.4); border-radius: 50%;
            transform: translate(-50%, -50%); box-shadow: 0 0 100px 50px white;
            opacity: 0; transition: all 1.5s ease; z-index: 1; pointer-events: none;
        }
        section.active .light-glow { width: 120vw; height: 120vw; opacity: 0.15; }

        /* 강조 섹션 (100% 0원) */
        .highlight-section { background: #000; color: #fff; text-align: center; }
        .highlight-text { font-size: clamp(40px, 10vw, 110px); font-weight: 900; letter-spacing: -3px; line-height: 1; color: #fff; }
        .highlight-sub { font-size: 24px; margin-top: 20px; color: #ff3b30; font-weight: 700; }

        .reveal { opacity: 0; transform: translateY(40px); transition: all 1.1s cubic-bezier(0.22, 1, 0.36, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }

        /* 화이트 섹션 */
        .white-section { background: #fff; color: #000; padding: 100px 24px; }
        .white-section h2 { font-size: clamp(36px, 8vw, 56px); font-weight: 800; letter-spacing: -1.5px; margin-bottom: 20px; }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; width: 100%; max-width: 1200px; }
        .card { background: #f7f7f7; padding: 45px; border-radius: 35px; border: 1px solid rgba(0,0,0,0.05); }

        /* 마지막 신청 섹션 */
        .apply-section { background: #fff; color: #000; text-align: center; }
        .cta-btn { 
            display: inline-block; margin-top: 40px; padding: 25px 60px; background: #000; color: #fff; 
            font-size: 24px; font-weight: 800; border-radius: 100px; text-decoration: none;
            transition: transform 0.3s ease;
        }
        .cta-btn:hover { transform: scale(1.05); }

        .footer { padding: 60px; text-align: center; font-size: 14px; opacity: 0.4; scroll-snap-align: end; background: #fff; color: #000; line-height: 1.6; }
    </style>
</head>
<body>

